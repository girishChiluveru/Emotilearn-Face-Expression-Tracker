# ============================================================================
# Emotilearn Backend Configuration (.env.example)
# ============================================================================
# Copy this file to .env and update values for your environment
# NEVER commit .env to version control
# ============================================================================

# ── Server Configuration ──────────────────────────────────────────────────────
NODE_ENV=development                          # development, staging, production
PORT=3000                                      # Express server port
FRONTEND_URL=http://localhost:5173            # Frontend URL for CORS
SOCKET_CORS_ORIGIN=http://localhost:5173      # WebSocket CORS origin

# ── Database Configuration ────────────────────────────────────────────────────
w=mongodb://localhost:27017/emotilearn
# Example for Atlas: mongodb+srv://user:pass@cluster.mongodb.net/emotilearn
DB_NAME=emotilearn

# ── JWT Authentication ───────────────────────────────────────────────────────
# Generate random secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secret-key-change-in-production-32-chars-minimum
JWT_EXPIRY=24h                                 # Token expiration time

# ── AI Service Configuration ─────────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8000          # TransformerModel FastAPI URL
AI_SERVICE_TIMEOUT=30000                      # Timeout in milliseconds

# ── AWS Configuration (for S3 file storage) ──────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=emotilearn-uploads
AWS_S3_ENDPOINT=https://s3.amazonaws.com      # Optional: for custom S3

# ── Secrets Manager (AWS) ────────────────────────────────────────────────────
AWS_SECRETS_MANAGER_REGION=us-east-1
AWS_SECRETS_NAME=emotilearn/backend

# ── Redis Configuration (for production caching & sessions) ───────────────────
REDIS_URL=redis://localhost:6379              # Leave empty for in-memory cache
REDIS_PASSWORD=                               # Optional
REDIS_DB=0

# ── Email Configuration (for notifications) ──────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@emotilearn.com

# ── Logging Configuration ────────────────────────────────────────────────────
LOG_LEVEL=info                                 # error, warn, info, debug
LOG_FILE=logs/emotilearn.log
LOG_MAX_SIZE=10m                               # Max log file size
LOG_MAX_FILES=7                                # Number of log files to keep

# ── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000                    # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100                    # Requests per window
RATE_LIMIT_LOGIN_MAX=5                         # Login attempts per window

# ── CORS Configuration ───────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
ALLOWED_HEADERS=Content-Type,Authorization,X-CSRF-Token,Idempotency-Key

# ── File Upload Configuration ────────────────────────────────────────────────
MAX_FILE_SIZE=52428800                         # 50MB in bytes
UPLOAD_DIR=./photos
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp

# ── Session Configuration ────────────────────────────────────────────────────
SESSION_TIMEOUT=86400000                       # 24 hours in milliseconds
SESSION_COOKIE_SECURE=false                    # true in production (requires HTTPS)
SESSION_COOKIE_SAME_SITE=strict                # strict, lax, none

# ── Feature Flags ────────────────────────────────────────────────────────────
ENABLE_ANALYTICS=true
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_SOCKET_LOGGING=false
ENABLE_REQUEST_LOGGING=true

# ── Monitoring & APM (Optional) ───────────────────────────────────────────────
SENTRY_DSN=                                    # Sentry error tracking
DATADOG_API_KEY=                               # Datadog APM
NEW_RELIC_LICENSE_KEY=                         # New Relic APM

# ── Admin Credentials (use Secrets Manager in production) ──────────────────────
ADMIN_DEFAULT_ID=admin@emotilearn.com
ADMIN_DEFAULT_PASSWORD=                        # Set strong password, use .env only for dev
ADMIN_JWT_SECRET=your-admin-jwt-secret-here

# ── Testing Configuration ────────────────────────────────────────────────────
TEST_MONGODB_URL=mongodb://localhost:27017/emotilearn-test
TEST_JWT_SECRET=test-secret-key
TEST_TIMEOUT=10000

# ============================================================================
# Security Notes:
# - JWT_SECRET: Use at least 32 characters
# - Rotate JWT_SECRET every 90 days in production
# - Never use sample values in production
# - Store sensitive values in AWS Secrets Manager or similar
# - Require HTTPS in production (SESSION_COOKIE_SECURE=true)
# - Use environment-specific configs: .env.production, .env.staging
# ============================================================================
