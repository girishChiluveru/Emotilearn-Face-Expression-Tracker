# ──────────────────────────────────────────────────────────────────────────────
# .env.example — TransformerModel AI Service
# Copy this file to .env and fill in your values.
# .env is git-ignored; .env.example is committed as documentation.
# ──────────────────────────────────────────────────────────────────────────────

# Path to the directory containing trained model artifacts.
# Relative paths are resolved from TransformerModel/ root.
# Default: artifacts
ARTIFACTS_DIR=artifacts

# Comma-separated list of allowed CORS origins for the FastAPI server.
# Example for production: https://yourapp.com,https://www.yourapp.com
ALLOWED_ORIGINS=http://localhost:5173

# Host and port for uvicorn
HOST=0.0.0.0
PORT=8000

# Rate limiting — see slowapi docs for syntax examples:
#   "100/minute", "1000/hour", "10/second"
RATE_LIMIT=100/minute
